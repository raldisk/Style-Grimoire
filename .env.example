# ── Sandbox mode (claude.ai artifact) ───────────────────────
# No key needed — auth is injected by the runtime.

# ── Self-hosted / standalone mode ───────────────────────────
# Set this on the SERVER (not in browser). Never commit a real key.
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Optional: change server port (default: 3000)
PORT=3000
